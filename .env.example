# Set these in Vercel: Project → Settings → Environment Variables (not in frontend .env).
# The api/ serverless functions read them; the browser never sees the webhook URL.
#production
CONTACT_WEBHOOK_URL="Your Discord webhook URL for contact form"
JOIN_US_WEBHOOK_URL="Your Discord webhook URL for join form"

#local testing
# VITE_CONTACT_WEBHOOK_URL="your Discord webhook URL for contact form"
# VITE_JOIN_US_WEBHOOK_URL="Your Discord webhook URL for join form"